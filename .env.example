PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=file:./casafood.db
# Required only for remote SQLite (e.g. Turso/libSQL) in production
# DATABASE_AUTH_TOKEN=

# Vercel Blob storage token for media uploads in production.
# Required on Vercel — the serverless filesystem is read-only, so local media
# storage fails. Create a Blob store in the Vercel dashboard and this is set
# automatically. Leave unset locally to use on-disk storage in public/media.
BLOB_READ_WRITE_TOKEN=

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_
